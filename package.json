{
    "name": "skills-config",
    "type": "module",
    "version": "0.0.0",
    "packageManager": "pnpm@10.33.2",
    "description": "Manage AI agent skills from git repos",
    "author": "",
    "license": "MIT",
    "keywords": [],
    "bin": {
        "skills-config": "./bin/skills-config.mjs"
    },
    "files": [
        "bin",
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "lint": "eslint .",
        "lint:fix": "eslint --fix",
        "prepublishOnly": "pnpm build",
        "prepare": "git submodule update --init --recursive && simple-git-hooks && pnpm start"
    },
    "dependencies": {
        "citty": "^0.2.2",
        "giget": "^3.2.0",
        "jiti": "^2.7.0",
        "tinyglobby": "^0.2.16",
        "xdg-basedir": "^5.1.0"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^9.0.0",
        "@lonewolfyx/tsconfig": "^0.0.6",
        "@types/node": "^25.9.1",
        "eslint": "^10.4.0",
        "nano-staged": "^1.0.2",
        "picocolors": "^1.1.1",
        "simple-git-hooks": "^2.13.1",
        "tsdown": "^0.22.0",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3"
    },
    "simple-git-hooks": {
        "pre-commit": "npx nano-staged",
        "commit-msg": "node scripts/verify-commit.js"
    },
    "nano-staged": {
        "*": "eslint --fix"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org",
        "access": "public"
    }
}
