{
    "name": "skills-config",
    "type": "module",
    "version": "0.0.1",
    "packageManager": "pnpm@10.33.2",
    "description": "Declarative Git skills manager for AI coding agents. Define skills in skills.config.ts and automatically provision them during npm install / prepare.",
    "author": "lonewolfyx",
    "license": "MIT",
    "homepage": "https://github.com/lonewolfyx/skills-config",
    "bugs": {
        "url": "https://github.com/lonewolfyx/skills-config/issues"
    },
    "keywords": [
        "skills",
        "skills-config",
        "github-skills"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "main": "./dist/index.mjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "bin": {
        "skills-config": "./bin/skills-config.mjs"
    },
    "files": [
        "bin",
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "prepublishOnly": "pnpm build",
        "prepare": "git submodule update --init --recursive && simple-git-hooks"
    },
    "dependencies": {
        "@clack/prompts": "^1.4.0",
        "citty": "^0.2.2",
        "giget": "^3.2.0",
        "glob": "^13.0.6",
        "jiti": "^2.7.0",
        "xdg-basedir": "^5.1.0"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^9.0.0",
        "@lonewolfyx/tsconfig": "^0.0.6",
        "@types/node": "^25.9.1",
        "eslint": "^10.4.0",
        "lint-staged": "^17.0.5",
        "picocolors": "^1.1.1",
        "simple-git-hooks": "^2.13.1",
        "tsdown": "^0.22.0",
        "tsx": "^4.22.3",
        "typescript": "^6.0.3"
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged",
        "commit-msg": "node scripts/verify-commit.js"
    },
    "lint-staged": {
        "*": "eslint --fix"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org",
        "access": "public"
    }
}
